# KaJota mobile — Breet Builder Grant (Jun 15, 2026 deadline) env template.
#
# Copy to `.env.breet` (gitignored) before running the Breet integration
# flow. Pairs with docs/HACKS.md → "Breet Builder Grant" for the full
# walkthrough + Loom recording script.

# ─────────────────────────────────────────────────────────────────────
# Breet API credentials
# ─────────────────────────────────────────────────────────────────────
#
# Breet uses THREE headers on every request (verified Jun 15 from
# https://docs.breet.io/api-reference/introduction):
#
#   x-app-id        long-lived application identifier
#   x-app-secret    paired secret (treat like a password / private key)
#   X-Breet-Env     "development" or "production" — picks which env
#                   the request routes to. A request missing this
#                   header is rejected.
#
# All three are server-side only — the mobile app NEVER holds them.
# The mobile calls KaJota's backend, which proxies to Breet with
# these credentials attached.
#
# Where to get them: log in to https://dashboard.breet.io →
# Developers → API Credentials. Requires a Business-tier account;
# personal/consumer accounts don't see the Developers section. If
# you don't see it, email sales@breet.io or book the demo CTA on
# breet.io/crypto-stablecoin-api to provision business access.

BREET_APP_ID=
BREET_APP_SECRET=
# development (sandbox) while iterating; production for the Loom + live
BREET_ENV=development

# Base URL includes /v1 — DON'T drop it. The bare host returns 404 on
# /addresses; only /v1/addresses resolves.
BREET_API_BASE=https://api.breet.io/v1

# Webhook signing secret — Breet posts a signed payload to your
# backend when a deposit is detected. The backend verifies HMAC-SHA256
# of the raw body keyed by this secret before crediting the user.
BREET_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Settlement currency
# ─────────────────────────────────────────────────────────────────────

# What Breet auto-converts inbound crypto to. Options: NGN / USDC /
# USDT / GHS. Match the credited wallet currency on KaJota's side.
BREET_SETTLEMENT_CURRENCY=NGN

# ─────────────────────────────────────────────────────────────────────
# Integration target
# ─────────────────────────────────────────────────────────────────────

# Which KaJota flow this build is wiring. Pick the one shipping
# fastest for the Loom demo:
#
#   wallet-deposit  - FundWallet screen gains a "Pay with crypto"
#                     option. Easiest fit; Breet generates per-user
#                     address, webhook credits the wallet.
#   order-payment   - PaymentOptionModal at checkout gains a
#                     stablecoin tile. Per-order address, webhook
#                     marks order paid.
#   withdraw        - WithdrawAmount gains an off-ramp option.
#                     Requires Breet's send-out API surface (less
#                     certain; verify with their docs).
BREET_INTEGRATION_TARGET=wallet-deposit

# ─────────────────────────────────────────────────────────────────────
# Webhook receiver
# ─────────────────────────────────────────────────────────────────────

# Public URL where Breet's webhook lands. Local dev: tunnel via
# ngrok / cloudflare; production: kajota-mobile-backend `hackathon/breet`
# branch exposing /api/v1/webhooks/breet/deposit.
BREET_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────
# Compliance
# ─────────────────────────────────────────────────────────────────────

# Breet requires KYC/KYB. KaJota already collects KYC via the
# existing onboarding flow; map the existing fields to Breet's
# customer-create endpoint. Document the field mapping in HACKS.md.

